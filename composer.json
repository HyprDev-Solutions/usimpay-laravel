{
    "name": "qandeez/usimpay-laravel",
    "description": "Laravel package for USIMPay payment initialization, checksum generation, and payment verification.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "usimpay",
        "payment",
        "gateway",
        "fpx"
    ],
    "autoload": {
        "psr-4": {
            "Qandeez\\USIMPay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Qandeez\\USIMPay\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/log": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Qandeez\\USIMPay\\USIMPayServiceProvider"
            ],
            "aliases": {
                "USIMPay": "Qandeez\\USIMPay\\Facades\\USIMPay"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
